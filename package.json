{
  "name": "engineering-knowledge-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ekg": "./dist/cli/main.js"
  },
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node scripts/copy-static-assets.mjs && node scripts/prepare-bin.mjs",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:acceptance": "vitest run tests/acceptance",
    "test:rust": "cargo test --workspace",
    "test:rust:release": "cargo test --release --workspace",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "^12.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "axe-core": "^4.12.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
